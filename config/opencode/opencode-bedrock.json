{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "argocd app get *": "allow",
            "ls *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "which *": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "patch": "allow",
        "webfetch": "allow"
    },
    "small_model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0",
    "provider": {
        "amazon-bedrock": {
            "options": {
                "profile": "bedrock"
            }
        }
    },
    "mcp": {
        "notion": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp"
        },
        "jira": {
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp"
        }
    }
}
