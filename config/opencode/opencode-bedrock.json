{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
    "permission": {
        "bash": {
            "*": "ask",
            "argocd app get *": "allow",
            "cat ~/.config/opencode/memory/MEMORY.md": "allow",
            "ls *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "which *": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "patch": "allow",
        "webfetch": "allow",
        "external_directory": {
            "~/.config/opencode/memory/**": "allow"
        }
    },
    "small_model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0",
    "provider": {
        "amazon-bedrock": {
            "options": {
                "profile": "bedrock"
            }
        }
    },
    "mcp": {
        "notion": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp",
            "enabled": false,
        },
        "jira": {
            "type": "remote",
            "url": "https://mcp.atlassian.com/v1/mcp",
            "enabled": false
        },
        "slack": {
            "type": "local",
            "command": ["bash", "-c", "$HOME/.config/opencode/slack-mcp.sh"],
            "enabled": false
        }
    },
    "tools": {
        "slack_slack_post_message": false,
        "slack_slack_reply_to_thread": false,
        "slack_slack_add_reaction": false
    }
}
