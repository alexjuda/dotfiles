{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "argocd app get *": "allow",
            "ls *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "which *": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "patch": "allow",
        "webfetch": "allow"
    },
    "agent": {
        "reader-bedrock": {
            "mode": "primary",
            "model": "amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0",
            "tools": {
                "bash": false,
            },
        },
    },
    "provider": {
        "amazon-bedrock": {
            "options": {
                "profile": "bedrock"
            }
        },
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1"
            },
            "models": {
                "qwen3-coder-30b": {
                    "name": "qwen/qwen3-coder-30b"
                }
            }
        }
    },
    "mcp": {
        "notion": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp"
        }
    }
}
