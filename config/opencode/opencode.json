{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "engram": {
            "command": [
                "/home/alex/.local/share/aj-eget-bins/engram",
                "mcp",
                "--tools=agent"
            ],
            "enabled": true,
            "type": "local"
        }
    },
    "permission": {
        "bash": {
            "*": "ask",
            "argocd app get *": "allow",
            "ls *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "which *": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "patch": "allow",
        "webfetch": "allow"
    }
}
