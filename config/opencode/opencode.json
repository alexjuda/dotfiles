{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "ask",
            "ls *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "which *": "allow"
        },
        "edit": "allow",
        "read": "allow",
        "grep": "allow",
        "patch": "allow",
        "webfetch": "allow"
    },
    "agent": {
        "reader-bedrock": {
            "mode": "primary",
            "model": "amazon-bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0",
            "tools": {
                "bash": false,
            },
        },
    },
    "small_model": "amazon-bedrock/anthropic.claude-haiku-4-5-20251001-v1:0",
    "provider": {
        "amazon-bedrock": {
            "options": {
                "profile": "bedrock"
            }
        }
    }
}
